    );
    const from = statusChange ? safeDisplayValue(statusChange.from) : "ж—?;
    const to = statusChange ? safeDisplayValue(statusChange.to) : "ж—?;
    return `${owner}пјҡд»Јзҗ?${proxyUsername} зҠ¶жҖ?${statusLabel(from)} -> ${statusLabel(to)}пј?{location}пјү`;
  }

  if (log.action === "user_proxy_entry_create") {
    const owner = typeof detail.username === "string" ? detail.username : "з”ЁжҲ·";
    const proxyUsername = typeof detail.proxyEntryUsername === "string" ? detail.proxyEntryUsername : "ж–°д»Јзҗ?;
    const source = typeof detail.passwordSource === "string" ? detail.passwordSource : "generated";
    const location = formatLocation(
      typeof detail.targetCountry === "string" ? detail.targetCountry : null,
      typeof detail.targetRegion === "string" ? detail.targetRegion : null,
      typeof detail.targetCity === "string" ? detail.targetCity : null
    );
    return `${owner}пјҡе·ІиҮӘеҠ©еҲӣе»әд»ЈзҗҶ ${proxyUsername}пј?{location}пјҢеҜҶз ?{source === "generated" ? "зі»з»ҹз”ҹжҲҗ" : "жүӢеҠЁеЎ«еҶҷ"}пјү`;
  }

  if (log.action === "user_settings_update") {
    const changes = isPlainRecord(detail.changes) ? detail.changes : {};
    const fieldSummaries = Object.entries(changes)
      .filter(([key]) => !isSensitiveField(key))
      .map(([key, value]) => formatOperationChange(key, value));
    return `${username || "з”ЁжҲ·"}пј?{fieldSummaries.length > 0 ? fieldSummaries.join("пј?) : "и®ҫзҪ®е·Іжӣҙж–?}`;
  }

  return safeDetailSummary(detail);
}

function operationFieldLabel(field: string): string {
  const labels: Record<string, string> = {
    status: "зҠ¶жҖ?,
    trafficQuotaGb: "жҖ»йўқеә?,
    maxProxyEntries: "д»ЈзҗҶдёҠйҷҗ",
    allowedCountries: "е…Ғи®ёеӣҪе®¶"
  };
  return labels[field] || field;
}

function safeDetailSummary(value: unknown): string {
  if (!isPlainRecord(value)) return "ж— иҜҰжғ?;
  const entries = Object.entries(value)
    .filter(([key]) => !isSensitiveField(key))
    .slice(0, 4)
    .map(([key, entryValue]) => `${operationFieldLabel(key)}=${safeDisplayValue(entryValue)}`);
  return entries.length > 0 ? entries.join("пј?) : "ж— еҸҜжҳҫзӨәиҜҰжғ…";
}

function safeDisplayValue(value: unknown): string {
  if (value === null || value === undefined) return "ж—?;
  if (typeof value === "string" || typeof value === "number" || typeof value === "boolean") return String(value);
  if (Array.isArray(value)) {
    if (value.every((item) => typeof item === "string")) {
      return value.map((item) => formatCountryCode(item)).join(", ");
    }
    return `${value.length} йЎ№`;
  }
  if (isPlainRecord(value)) return "е·Іи®°еҪ?;
  return "е·Іи®°еҪ?;
}

function formatOperationChange(field: string, value: unknown): string {
  const label = operationFieldLabel(field);
  if (field === "allowedCountries" && isPlainRecord(value)) {
    const from = safeDisplayValue(value.from);
    const to = safeDisplayValue(value.to);
    return `${label} ${from} -> ${to}`;
  }

  if (isPlainRecord(value) && "from" in value && "to" in value) {
    return `${label} ${safeDisplayValue(value.from)} -> ${safeDisplayValue(value.to)}`;
  }

  return label;
}

function isSensitiveField(field: string): boolean {
  const normalized = field.replace(/[^a-z0-9]/gi, "").toLowerCase();
  return /password|passwd|pwd|secret|token|apikey|privatekey|accesskey|credential|authorization|auth|bearer|cookie|session|jwt|csrf|signature/.test(normalized);
}

function isPlainRecord(value: unknown): value is Record<string, unknown> {
  return typeof value === "object" && value !== null && !Array.isArray(value);
}

function formatCountryCode(value: string): string {
  return countries.find((country) => country.value === value.toLowerCase())?.label || value.toUpperCase();
}

function isToday(date: string): boolean {
  return date === new Date().toISOString().slice(0, 10);
}

function isThisMonth(date: string): boolean {
  return date.startsWith(new Date().toISOString().slice(0, 7));
}

