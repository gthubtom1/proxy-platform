import React, { FormEvent, useEffect, useMemo, useState } from "react";
import { createRoot } from "react-dom/client";
import "./styles.css";

type AdminUser = {
  id: number;
  username: string;
  role: string;
  status: string;
  trafficQuotaBytes: string;
  trafficUsedBytes: string;
  allowedCountries?: string[];
  maxProxyEntries: number;
  maxConcurrentConnections: number;
  proxyEntryCount: number;
  createdAt: string;
  updatedAt: string;
};

type ProxyEntry = {
  id: number;
  userId: number;
  username: string;
  targetCountry: string;
  targetRegion: string | null;
  targetCity: string | null;
  currentUpstreamId: number | null;
  currentIp: string | null;
  currentCountry: string | null;
  currentRegion: string | null;
  currentCity: string | null;
  status: string;
  trafficUsedBytes: string;
  activeConnections: number;
  lastUsedAt: string | null;
  lastCheckedAt: string | null;
  createdAt: string;
  updatedAt: string;
  user: {
    id: number;
    username: string;
    status: string;
    trafficQuotaBytes: string;
    trafficUsedBytes: string;
  };
  lockedUpstream: {
    id: number;
    status: string;
    currentIp: string | null;
    country: string | null;
    region: string | null;
    city: string | null;
    latencyMs: number | null;
    lastCheckedAt: string | null;
  } | null;
};

type AuthUser = {
  id: number;
  username: string;
  role: AppMode;
};

type AuthSession = {
  token: string;
  user: AuthUser;
};

type LoginFormState = {
  username: string;
  password: string;
};

type UpstreamProxy = {
  id: number;
  host: string;
  port: number;
  username: string;
  status: string;
  currentIp: string | null;
  country: string | null;
  region: string | null;
  city: string | null;
  latencyMs: number | null;
  score: number;
  failCount: number;
  successCount: number;
  lastErrorType: string | null;
  lastCheckedAt: string | null;
  createdAt: string;
  updatedAt: string;
  scanLogs: Array<{
    id: number;
    success: boolean;
    exitIp: string | null;
    country: string | null;
    region: string | null;
    city: string | null;
    latencyMs: number | null;
    errorType: string | null;
    message: string | null;
    createdAt: string;
  }>;
};

type TrafficDaily = {
  id: number;
  userId: number;
  proxyEntryId: number;
  date: string;
  bytesUp: string;
  bytesDown: string;
  totalBytes: string;
  connections: number;
  user: {
    id: number;
    username: string;
  };
  proxyEntry: {
    id: number;
    username: string;
    targetCountry: string;
    targetRegion: string | null;
    targetCity: string | null;
  };
};

type UpstreamImportResponse = {
  created: number;
  duplicates: number;
  failed: number;
  items: Array<
    | {
        ok: true;
        lineNumber: number;
        id: number;
        host: string;
        port: number;
        username: string;
        action: "created" | "duplicate";
      }
    | {
        ok: false;
        lineNumber: number;
        error: string;
      }
  >;
};

type CreatedProxyResponse = {
  ok: true;
  clientProxy: {
    host: string;
    port: number;
    username: string;
    password: string;
    copyText: string;
  };
};

type LoginResponse = {
  token: string;
  user: AuthUser;
};

type UserDashboardResponse = {
  user: AdminUser;
  entries: ProxyEntry[];
  rows: TrafficDaily[];
};

type CreateUserResponse = {
  ok?: boolean;
  user?: AdminUser;
  initialPassword?: string;
  error?: string;
};

type CreateUserResult = {
  user: AdminUser;
  initialPassword: string;
};

type CreateProxyEntryResult = {
  copies: string[];
  failed: number;
};

type ResetUserPasswordResponse = {
  ok?: boolean;
  user?: AdminUser;
  newPassword?: string;
  error?: string;
};

type UpdateUserResponse = {
  ok?: boolean;
  user?: AdminUser;
  error?: string;
};

type UpdateProxyEntryStatusResponse = {
  ok?: boolean;
  entry?: {
    id: number;
    username: string;
    status: string;
    currentUpstreamId: number | null;
    currentIp: string | null;
    currentCountry: string | null;
    currentRegion: string | null;
    currentCity: string | null;
    updatedAt: string;
  };
  error?: string;
};

type OperationLog = {
  id: number;
  actorUserId: number | null;
  action: string;
  targetType: string;
  targetId: string;
  createdAt: string;
  actor: {
    id: number;
    username: string;
    role: string;
  } | null;
  detail: unknown;
};

type UserFormState = {
  username: string;
  password: string;
  trafficQuotaGb: string;
  maxProxyEntries: string;
  allowedCountries: string[];
};

type UserSettingsFormState = {
  status: string;
  trafficQuotaGb: string;
  maxProxyEntries: string;
  allowedCountries: string[];
};

type EntryFormState = {
  userId: string;
  targetCountry: string;
  targetRegion: string;
  targetCity: string;
  count: string;
};

type AppMode = "admin" | "user";
type AdminPage = "dashboard" | "users" | "upstreams" | "geo" | "proxies" | "logs" | "settings";
type UserPage = "home" | "generate" | "proxies" | "traffic";

type ViteImportMeta = ImportMeta & {
  env?: {
    VITE_APP_SURFACE?: AppMode;
    VITE_API_BASE_URL?: string;
  };
};

type RegionInventory = {
  bad: number;
  city: string | null;
  country: string | null;
  free: number;
  key: string;
  label: string;
  locked: number;
  region: string | null;
  total: number;
};

type AdminReadOnlyIntent = {
  country: string | null;
  page: "logs" | "proxies" | "upstreams" | "users";
  search: string;
  token: number;
};

type SystemConfig = {
  gatewayPort: number;
  supportedCountries: string[];
  scanBatchSize: number;
  scanConcurrency: number;
  scanTimeoutMs: number;
  scanIntervalMs: number;
  geoCacheTtlMs: number;
  workerRepeat: boolean;
  backupStatus: string;
};

const env = (import.meta as ViteImportMeta).env;
const appSurface: AppMode = env?.VITE_APP_SURFACE === "user" ? "user" : "admin";
const apiBase = env?.VITE_API_BASE_URL || "http://127.0.0.1:3110";
const gatewayDisplay = "VPS_IP:18001";
const countries = [
  { value: "us", label: "US" },
  { value: "gb", label: "GB" },
  { value: "fr", label: "FR" },
  { value: "ca", label: "CA" },
  { value: "au", label: "AU" }
];

function App() {
  const [adminPage, setAdminPage] = useState<AdminPage>("dashboard");
  const [userPage, setUserPage] = useState<UserPage>("home");
  const storageKey = `proxy-platform:${appSurface}:auth`;
  const [session, setSession] = useState<AuthSession | null>(() => readStoredSession(storageKey, appSurface));
  const [loginForm, setLoginForm] = useState<LoginFormState>({ username: "", password: "" });
  const [users, setUsers] = useState<AdminUser[]>([]);
  const [entries, setEntries] = useState<ProxyEntry[]>([]);
  const [upstreams, setUpstreams] = useState<UpstreamProxy[]>([]);
  const [trafficRows, setTrafficRows] = useState<TrafficDaily[]>([]);
  const [operationLogs, setOperationLogs] = useState<OperationLog[]>([]);
  const [systemConfig, setSystemConfig] = useState<SystemConfig | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [isSaving, setIsSaving] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [notice, setNotice] = useState<string | null>(null);
  const [lastLoadedAt, setLastLoadedAt] = useState<Date | null>(null);
  const [createdCopies, setCreatedCopies] = useState<string[]>([]);
  const [importResult, setImportResult] = useState<UpstreamImportResponse | null>(null);
  const [upstreamText, setUpstreamText] = useState("");
  const [adminReadOnlyIntent, setAdminReadOnlyIntent] = useState<AdminReadOnlyIntent | null>(null);
  const [userForm, setUserForm] = useState<UserFormState>({
    username: "",
    password: "",
    trafficQuotaGb: "0",
    maxProxyEntries: "10",
    allowedCountries: countries.map((country) => country.value)
  });
  const [entryForm, setEntryForm] = useState<EntryFormState>({
    userId: "",
    targetCountry: "us",
    targetRegion: "",
    targetCity: "",
    count: "1"
  });

  const currentUser = appSurface === "user" ? users[0] ?? null : null;
  const upstreamStats = useMemo(() => countStatuses(upstreams.map((upstream) => upstream.status)), [upstreams]);
  const entryStats = useMemo(() => countStatuses(entries.map((entry) => entry.status)), [entries]);
  const regions = useMemo(() => buildRegionInventory(upstreams), [upstreams]);
  const activeUsers = users.filter((user) => user.status === "active").length;
  const activeEntries = entries.filter((entry) => entry.status === "active").length;
  const todayTraffic = sumStrings(trafficRows.filter((row) => isToday(row.date)).map((row) => row.totalBytes));
  const monthTraffic = sumStrings(trafficRows.filter((row) => isThisMonth(row.date)).map((row) => row.totalBytes));

  useEffect(() => {
    if (!session) {
      setIsLoading(false);
      return;
    }
    void loadAll();
  }, [session]);

  async function requestJson<T>(path: string, init?: RequestInit): Promise<T> {
    const response = await fetch(`${apiBase}${path}`, {
      ...init,
      headers: {
        ...(session ? { Authorization: `Bearer ${session.token}` } : {}),
        ...(init?.headers ?? {})
      }
    });
    const body = (await response.json()) as T & { error?: string };
    if (!response.ok) throw new Error(body.error || `иҜ·жұӮеӨұиҙҘпј?{path}`);
    return body;
  }

  async function loadAll() {
    if (!session) return;

    setIsLoading(true);
    setError(null);

    try {
      if (appSurface === "user") {
        const dashboard = await requestJson<UserDashboardResponse>("/api/user/dashboard");
        setUsers([dashboard.user]);
        setEntries(dashboard.entries);
        setTrafficRows(dashboard.rows);
        setUpstreams([]);
        setOperationLogs([]);
        setSystemConfig(null);
        setLastLoadedAt(new Date());
        return;
      }

      const [userBody, entryBody, upstreamBody, trafficBody, logBody, systemConfigBody] = await Promise.all([
        requestJson<{ users: AdminUser[] }>("/api/admin/users"),
        requestJson<{ entries: ProxyEntry[] }>("/api/admin/proxy-entries"),
        requestJson<{ upstreams: UpstreamProxy[] }>("/api/admin/upstreams"),
        requestJson<{ rows: TrafficDaily[] }>("/api/admin/traffic-daily"),
        requestJson<{ logs: OperationLog[] }>("/api/admin/operation-logs"),
        requestJson<{ config: SystemConfig }>("/api/admin/system-config")
      ]);

      setUsers(userBody.users);
      setEntries(entryBody.entries);
      setUpstreams(upstreamBody.upstreams);
      setTrafficRows(trafficBody.rows);
      setOperationLogs(logBody.logs);
      setSystemConfig(systemConfigBody.config);
      setLastLoadedAt(new Date());
    } catch (loadError) {
      setError(loadError instanceof Error ? loadError.message : "иҜ»еҸ–ж•°жҚ®еӨұиҙҘ");
    } finally {
      setIsLoading(false);
    }
  }

  async function refreshAll() {
    await loadAll();
    setNotice("ж•°жҚ®е·ІеҲ·ж–°гҖ?);
  }

  function openAdminReadOnlyPage(page: "logs" | "proxies" | "upstreams" | "users", options: { country?: string | null; search?: string }) {
    setAdminPage(page);
    setAdminReadOnlyIntent({
      page,
      country: options.country ?? null,
      search: options.search?.trim() || "",
      token: Date.now()
    });
  }

  async function login(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();
    setIsSaving(true);
    setError(null);
    setNotice(null);

    try {
      const body = await requestJson<LoginResponse>(`/api/${appSurface}/login`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          username: loginForm.username.trim(),
          password: loginForm.password
        })
      });
      const nextSession = { token: body.token, user: body.user };
      localStorage.setItem(storageKey, JSON.stringify(nextSession));
      setLoginForm({ username: "", password: "" });
      setSession(nextSession);
      setNotice("зҷ»еҪ•жҲҗеҠҹгҖ?);
    } catch (loginError) {
      setError(loginError instanceof Error ? loginError.message : "зҷ»еҪ•еӨұиҙҘ");
    } finally {
      setIsSaving(false);
    }
  }

  function logout() {
    localStorage.removeItem(storageKey);
    setSession(null);
    setUsers([]);
    setEntries([]);
    setUpstreams([]);
    setTrafficRows([]);
    setOperationLogs([]);
    setSystemConfig(null);
    setCreatedCopies([]);
    setLastLoadedAt(null);
  }

  async function createUser(event: FormEvent<HTMLFormElement>): Promise<CreateUserResult | null> {
    event.preventDefault();
    setIsSaving(true);
    setError(null);
    setNotice(null);

    try {
      const body = await requestJson<CreateUserResponse>("/api/admin/users", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          username: userForm.username.trim(),
          password: userForm.password.trim() || undefined,
          trafficQuotaGb: Number(userForm.trafficQuotaGb || 0),
          maxProxyEntries: Number(userForm.maxProxyEntries || 10),
          allowedCountries: userForm.allowedCountries
        })
      });
      if (!body.ok) throw new Error(body.error || "еҲӣе»әз”ЁжҲ·еӨұиҙҘ");
      setUserForm({
        username: "",
        password: "",
        trafficQuotaGb: "0",
        maxProxyEntries: "10",
        allowedCountries: countries.map((country) => country.value)
      });
      setNotice("з”ЁжҲ·е·ІеҲӣе»әгҖӮеҲқе§ӢеҜҶз ҒеҸӘдјҡжҳҫзӨәиҝҷдёҖеӣһпјҢиҜ·зҺ°еңЁдҝқеӯҳгҖ?);
      await loadAll();
      if (body.user && body.initialPassword) {
        return {
          user: body.user,
          initialPassword: body.initialPassword
        };
      }
      return null;
    } catch (createError) {
      setError(createError instanceof Error ? createError.message : "еҲӣе»әз”ЁжҲ·еӨұиҙҘ");
      return null;
    } finally {
      setIsSaving(false);
    }
  }

  async function resetUserPassword(userId: number, password: string): Promise<ResetUserPasswordResponse> {
    setIsSaving(true);
    setError(null);
    setNotice(null);

    try {
      const body = await requestJson<ResetUserPasswordResponse>(`/api/admin/users/${userId}/password-reset`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          password: password.trim() || undefined
        })
      });

      if (!body.ok || !body.newPassword) throw new Error(body.error || "йҮҚзҪ®еҜҶз ҒеӨұиҙҘ");
      if (body.user) {
        setUsers((current) => current.map((user) => (user.id === body.user?.id ? body.user : user)));
      }
      setNotice("еҜҶз Ғе·ІйҮҚзҪ®гҖӮж–°еҜҶз ҒеҸӘжҳҫзӨәиҝҷдёҖж¬ЎпјҢиҜ·зҺ°еңЁдҝқеӯҳгҖ?);
      await loadAll();
      return body;
    } catch (resetError) {
      const message = resetError instanceof Error ? resetError.message : "йҮҚзҪ®еҜҶз ҒеӨұиҙҘ";
      setError(message);
      return { ok: false, error: message };
    } finally {
      setIsSaving(false);
    }
  }

  async function updateUserSettings(userId: number, form: UserSettingsFormState): Promise<UpdateUserResponse> {
    setIsSaving(true);
    setError(null);
    setNotice(null);

    try {
      const body = await requestJson<UpdateUserResponse>(`/api/admin/users/${userId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          status: form.status,
          trafficQuotaGb: Number(form.trafficQuotaGb || 0),
          maxProxyEntries: Number(form.maxProxyEntries || 1),
          allowedCountries: form.allowedCountries
        })
      });

      if (!body.ok || !body.user) throw new Error(body.error || "дҝқеӯҳз”ЁжҲ·и®ҫзҪ®еӨұиҙҘ");
      setUsers((current) => current.map((user) => (user.id === body.user?.id ? body.user : user)));
      setNotice("з”ЁжҲ·и®ҫзҪ®е·ІдҝқеӯҳпјҢе№¶е·ІеҶҷе…Ҙж“ҚдҪңж—Ҙеҝ—гҖ?);
      await loadAll();
      return body;
    } catch (updateError) {
      const message = updateError instanceof Error ? updateError.message : "дҝқеӯҳз”ЁжҲ·и®ҫзҪ®еӨұиҙҘ";
      setError(message);
      return { ok: false, error: message };
    } finally {
      setIsSaving(false);
    }
  }

  async function updateProxyEntryStatus(entryId: number, status: "active" | "disabled"): Promise<UpdateProxyEntryStatusResponse> {
    setIsSaving(true);
    setError(null);
    setNotice(null);

    try {
      const body = await requestJson<UpdateProxyEntryStatusResponse>(`/api/admin/proxy-entries/${entryId}/status`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ status })
      });

      if (!body.ok || !body.entry) throw new Error(body.error || "дҝ®ж”№д»ЈзҗҶзҠ¶жҖҒеӨұиҙ?);
      setEntries((current) =>
        current.map((entry) =>
          entry.id === body.entry?.id
            ? {
                ...entry,
                status: body.entry.status,
                currentUpstreamId: body.entry.currentUpstreamId,
                currentIp: body.entry.currentIp,
                currentCountry: body.entry.currentCountry,
                currentRegion: body.entry.currentRegion,
                currentCity: body.entry.currentCity,
                updatedAt: body.entry.updatedAt
              }
            : entry
        )
      );
      setNotice(
        status === "disabled"
          ? "д»ЈзҗҶе·ІеҒңз”ЁгҖӮеҪ“еүҚз»‘е®ҡе·ІжҢүи§„еҲҷеӨ„зҗҶпјҢе№¶е·ІеҶҷе…Ҙж“ҚдҪңж—Ҙеҝ—гҖ?
          : "д»ЈзҗҶе·ІеҗҜз”ЁгҖӮзі»з»ҹе·Іе°қиҜ•йҮҚж–°еҢ№й…ҚеҸҜз”ЁдёҠжёёпјҢе№¶е·ІеҶҷе…Ҙж“ҚдҪңж—Ҙеҝ—гҖ?
      );
      await loadAll();
      return body;
    } catch (updateError) {
      const message = updateError instanceof Error ? updateError.message : "дҝ®ж”№д»ЈзҗҶзҠ¶жҖҒеӨұиҙ?;
      setError(message);
      return { ok: false, error: message };
    } finally {
      setIsSaving(false);
    }
  }

  async function importUpstreams(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();
    setIsSaving(true);
    setError(null);
    setNotice(null);
    setImportResult(null);

    try {
      const response = await fetch(`${apiBase}/api/admin/upstreams/import`, {
        method: "POST",
        headers: { Authorization: `Bearer ${session?.token ?? ""}`, "Content-Type": "application/json" },
        body: JSON.stringify({ text: upstreamText })
      });
      const body = (await response.json()) as UpstreamImportResponse | { error?: string };
      if (!response.ok && response.status !== 207) {
        throw new Error("error" in body && body.error ? body.error : "еҜје…ҘдёҠжёёеӨұиҙҘ");
      }
      const result = body as UpstreamImportResponse;
      setImportResult(result);
      setNotice(`еҜје…Ҙе®ҢжҲҗпјҡж–°еў?${result.created} жқЎпјҢйҮҚеӨҚ ${result.duplicates} жқЎпјҢеӨұиҙҘ ${result.failed} жқЎгҖӮ`);
      if (result.created > 0 && result.failed === 0) setUpstreamText("");
      await loadAll();
    } catch (importError) {
      setError(importError instanceof Error ? importError.message : "еҜје…ҘдёҠжёёеӨұиҙҘ");
    } finally {
      setIsSaving(false);
    }
  }

  async function createEntries(event: FormEvent<HTMLFormElement>) {
    event.preventDefault();
    setIsSaving(true);
    setError(null);
    setNotice(null);
    setCreatedCopies([]);

    const count = Math.max(1, Math.min(20, Number(entryForm.count || 1)));
    const copies: string[] = [];
    let failed = 0;

    try {
      for (let index = 0; index < count; index += 1) {
        const response = await fetch(`${apiBase}/api/user/proxy-entries`, {
          method: "POST",
          headers: { Authorization: `Bearer ${session?.token ?? ""}`, "Content-Type": "application/json" },
          body: JSON.stringify({
            targetCountry: entryForm.targetCountry,
            targetRegion: entryForm.targetRegion.trim() || undefined,
            targetCity: entryForm.targetCity.trim() || undefined
          })
        });
        const body = (await response.json()) as CreatedProxyResponse | { error?: string };
        if (!response.ok || !("ok" in body) || !body.ok) {
          failed += 1;
          if (copies.length === 0) throw new Error("error" in body && body.error ? body.error : "з”ҹжҲҗд»ЈзҗҶеӨұиҙҘ");
          break;
        }
        copies.push(body.clientProxy.copyText);
      }

      setCreatedCopies(copies);
      setNotice(`е·Із”ҹжҲ?${copies.length} жқЎд»Јзҗ?{failed > 0 ? `пј?{failed} жқЎеӣ еә“еӯҳдёҚи¶іжңӘз”ҹжҲҗ` : ""}гҖӮеҜҶз ҒеҸӘжҳҫзӨәиҝҷдёҖж¬ЎгҖӮ`);
      await loadAll();
    } catch (createError) {
      setError(createError instanceof Error ? createError.message : "з”ҹжҲҗд»ЈзҗҶеӨұиҙҘ");
    } finally {
      setIsSaving(false);
    }
  }

  async function createAdminEntries(form: EntryFormState): Promise<CreateProxyEntryResult | null> {
    setIsSaving(true);
    setError(null);
    setNotice(null);
    setCreatedCopies([]);

    const count = Math.max(1, Math.min(20, Number(form.count || 1)));
    const copies: string[] = [];
    let failed = 0;
    const userId = Number(form.userId || 0);

    try {
      for (let index = 0; index < count; index += 1) {
        const response = await fetch(`${apiBase}/api/admin/proxy-entries`, {
          method: "POST",
          headers: { Authorization: `Bearer ${session?.token ?? ""}`, "Content-Type": "application/json" },
          body: JSON.stringify({
            userId,
            targetCountry: form.targetCountry,
            targetRegion: form.targetRegion.trim() || undefined,
            targetCity: form.targetCity.trim() || undefined
          })
        });
        const body = (await response.json()) as CreatedProxyResponse | { error?: string; ok?: false };
        if (!response.ok || ("ok" in body && body.ok === false)) {
          failed += 1;
          if (copies.length === 0) throw new Error("error" in body && body.error ? body.error : "еҲӣе»әд»ЈзҗҶеӨұиҙҘ");
          break;
        }
        if (!("clientProxy" in body)) {
          failed += 1;
          if (copies.length === 0) throw new Error("еҲӣе»әд»ЈзҗҶеӨұиҙҘ");
          break;
        }
        copies.push(body.clientProxy.copyText);
      }

      setCreatedCopies(copies);
      setNotice(`е·Із”ҹжҲ?${copies.length} жқЎд»Јзҗ?{failed > 0 ? `пјҢеҸҰжң?${failed} жқЎеӣ еә“еӯҳдёҚи¶іжңӘз”ҹжҲҗ` : ""}гҖӮеҜҶз ҒеҸӘжҳҫзӨәиҝҷдёҖеӣһгҖӮ`);
      await loadAll();
      return { copies, failed };
    } catch (createError) {
      setError(createError instanceof Error ? createError.message : "еҲӣе»әд»ЈзҗҶеӨұиҙҘ");
      return null;
    } finally {
      setIsSaving(false);
    }
  }

  async function copyText(text: string, successMessage: string) {
    setError(null);
    try {
      await navigator.clipboard.writeText(text);
      setNotice(successMessage);
    } catch {
      setNotice(null);
      setError("еӨҚеҲ¶еӨұиҙҘпјҢиҜ·жүӢеҠЁеӨҚеҲ¶иҝҷж®өеҶ…е®№гҖ?);
    }
  }

  return (
    <main className="app-shell">
      <Header
        surface={appSurface}
        onLogout={session ? logout : undefined}
        onRefresh={() => void refreshAll()}
        isLoading={isLoading || !session}
        lastLoadedAt={lastLoadedAt}
        username={session?.user.username}
      />
      <Messages error={error} notice={notice} />

      {!session ? (
        <LoginPanel form={loginForm} isSaving={isSaving} onSubmit={login} setForm={setLoginForm} surface={appSurface} />
      ) : appSurface === "admin" ? (
        <AdminApp
          activeEntries={activeEntries}
          activePage={adminPage}
          activeUsers={activeUsers}
          copyText={copyText}
          createAdminEntries={createAdminEntries}
          createUser={createUser}
          entries={entries}
          entryStats={entryStats}
          importResult={importResult}
          importUpstreams={importUpstreams}
          isLoading={isLoading}
          isSaving={isSaving}
          monthTraffic={monthTraffic}
          operationLogs={operationLogs}
          onOpenAdminReadOnlyPage={openAdminReadOnlyPage}
          readOnlyIntent={adminReadOnlyIntent}
          resetUserPassword={resetUserPassword}
          regions={regions}
          setActivePage={setAdminPage}
          setReadOnlyIntent={setAdminReadOnlyIntent}
          setUpstreamText={setUpstreamText}
          setUserForm={setUserForm}
          todayTraffic={todayTraffic}
          trafficRows={trafficRows}
          upstreamStats={upstreamStats}
          upstreamText={upstreamText}
          upstreams={upstreams}
          systemConfig={systemConfig}
          updateProxyEntryStatus={updateProxyEntryStatus}
          updateUserSettings={updateUserSettings}
          userForm={userForm}
          users={users}
        />
      ) : (
        <UserApp
          activePage={userPage}
          copyText={copyText}
          createEntries={createEntries}
          createdCopies={createdCopies}
          entries={entries}
          form={entryForm}
          isSaving={isSaving}
          selectedUser={currentUser}
          setActivePage={setUserPage}
