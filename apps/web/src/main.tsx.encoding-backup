function AdminLogs(props: {
  operationLogs: OperationLog[];
  readOnlyIntent: AdminReadOnlyIntent | null;
  setReadOnlyIntent: (intent: AdminReadOnlyIntent | null) => void;
  upstreams: UpstreamProxy[];
}) {
  const logs = props.upstreams.flatMap((upstream) =>
    upstream.scanLogs.map((log) => ({
      ...log,
      host: upstream.host,
      upstreamId: upstream.id
    }))
  );
  const [operationSearch, setOperationSearch] = useState("");
  const [operationActionFilter, setOperationActionFilter] = useState("all");
  const [scanSearch, setScanSearch] = useState("");
  const [scanStatusFilter, setScanStatusFilter] = useState("all");
  const filteredOperationLogs = props.operationLogs.filter((log) => {
    const query = operationSearch.trim().toLowerCase();
    const summary = summarizeOperationLog(log).toLowerCase();
    const matchesSearch =
      !query ||
      log.action.toLowerCase().includes(query) ||
      log.targetType.toLowerCase().includes(query) ||
      log.targetId.toLowerCase().includes(query) ||
      (log.actor?.username || "").toLowerCase().includes(query) ||
      summary.includes(query);
    const matchesAction = operationActionFilter === "all" || log.action === operationActionFilter;
    return matchesSearch && matchesAction;
  });
  const filteredLogs = logs.filter((log) => {
    const query = scanSearch.trim().toLowerCase();
    const matchesSearch =
      !query ||
      String(log.upstreamId).toLowerCase().includes(query) ||
      log.host.toLowerCase().includes(query) ||
      (log.exitIp || "").toLowerCase().includes(query) ||
      formatLocation(log.country, log.region, log.city).toLowerCase().includes(query) ||
      (log.message || "").toLowerCase().includes(query) ||
      (log.errorType || "").toLowerCase().includes(query);
    const matchesStatus =
      scanStatusFilter === "all" ||
      (scanStatusFilter === "success" && log.success) ||
