function UserHome(props: {
  user: AdminUser;
  entries: ProxyEntry[];
  trafficRows: TrafficDaily[];
  onNavigate: (page: UserPage) => void;
}) {
  const quota = Number(props.user.trafficQuotaBytes);
  const used = Number(props.user.trafficUsedBytes);
  const remaining = quota > 0 ? Math.max(0, quota - used) : 0;
  const today = sumStrings(props.trafficRows.filter((row) => isToday(row.date)).map((row) => row.totalBytes));
  const month = sumStrings(props.trafficRows.filter((row) => isThisMonth(row.date)).map((row) => row.totalBytes));
  const percent = quotaPercent(used, quota);

  return (
    <>
      <section className="metric-grid">
        <Metric label="еү©дҪҷйўқеәҰ" value={quota > 0 ? formatBytes(String(remaining)) : "дёҚйҷҗ"} tone={quota > 0 && percent >= 85 ? "warn" : undefined} />
        <Metric label="е·Із”ЁжөҒйҮҸ" value={formatBytes(props.user.trafficUsedBytes)} />
        <Metric label="д»Ҡж—ҘжөҒйҮҸ" value={formatBytes(String(today))} />
        <Metric label="жң¬жңҲжөҒйҮҸ" value={formatBytes(String(month))} />
        <Metric label="жҲ‘зҡ„д»ЈзҗҶ" value={`${props.entries.length}/${props.user.maxProxyEntries}`} />
        <Metric label="еҗҜз”Ёд»ЈзҗҶ" value={String(props.entries.filter((entry) => entry.status === "active").length)} />
      </section>

      <section className="split-grid">
        <Panel title="йўқеәҰ">
          <div className="progress-block">
            <div className="progress-head">
              <span>{formatBytes(props.user.trafficUsedBytes)}</span>
              <span>{formatQuota(props.user.trafficQuotaBytes)}</span>
            </div>
            <div className="progress-track">
              <span style={{ width: `${percent}%` }} />
            </div>
          </div>
          {quota > 0 && percent >= 85 && (
            <div className="alert-list quota-alert">
              <span>
                {percent >= 100
                  ? "йўқеәҰе·Із”Ёе®ҢпјҢиҜ·иҒ”зі»з®ЎзҗҶе‘ҳеӨ„зҗҶгҖ?
                  : `йўқеәҰе·ІдҪҝз”?${percent}%пјҢе»әи®®жҸҗеүҚиҒ”зі»з®ЎзҗҶе‘ҳгҖӮ`}
              </span>
            </div>
          )}
        </Panel>
        <Panel title="жңҖиҝ‘д»Јзҗ?>
          {props.entries.length === 0 ? (
            <EmptyState text="жҡӮж— д»ЈзҗҶгҖ? />
          ) : (
            <div className="compact-list">
              {props.entries.slice(0, 4).map((entry) => (
                <span key={entry.id}>
                  <strong>{entry.username}</strong>
                  <em>{formatLocation(entry.targetCountry, entry.targetRegion, entry.targetCity)}</em>
                </span>
              ))}
            </div>
          )}
        </Panel>
