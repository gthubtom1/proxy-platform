NODE_ENV=development

API_PORT=3110
WEB_PORT=5173
WEB_ALLOWED_ORIGINS=http://127.0.0.1:5180,http://127.0.0.1:5181
ADMIN_WEB_ORIGIN=http://127.0.0.1:5180
USER_WEB_ORIGIN=http://127.0.0.1:5181
PROXY_GATEWAY_PORT=18001
# 对外暴露给客户端的代理主机地址，会拼进 copyText（host:port:用户名:密码）。
# 留空时默认使用 127.0.0.1（本地调试）；正式部署请填写 VPS 的公网 IP 或域名。
PUBLIC_PROXY_HOST=

# Set true only when API is behind a trusted reverse proxy such as Nginx.
TRUST_PROXY=false

GATEWAY_TEST_UPSTREAM_URL=
GATEWAY_TEST_UPSTREAM_HOST=
GATEWAY_TEST_UPSTREAM_PORT=
GATEWAY_TEST_UPSTREAM_USERNAME=
GATEWAY_TEST_UPSTREAM_PASSWORD=
GATEWAY_CONNECT_TIMEOUT_MS=20000
GATEWAY_TEST_USERNAME=test
GATEWAY_TEST_PASSWORD=test

# Database provider. Keep sqlite unless you really need higher write concurrency.
# sqlite = default, one local file. postgresql = optional VPS database service.
# If this changes, run prisma:generate and prisma:push again for @proxy-platform/db.
#   DATABASE_PROVIDER=postgresql npm run prisma:generate -w @proxy-platform/db
#   DATABASE_PROVIDER=postgresql npm run prisma:push -w @proxy-platform/db
DATABASE_PROVIDER=sqlite

# SQLite default:
DATABASE_URL=file:../../../data/proxy-platform.db
# PostgreSQL optional example. Enable it by replacing DATABASE_URL above and
# setting DATABASE_PROVIDER=postgresql. Replace CHANGE_ME with a strong password.
# DATABASE_URL=postgresql://proxy:CHANGE_ME@127.0.0.1:5432/proxy_platform

# Required for VPS pm2 deployment. Fill real values in .env before pm2 start.
ADMIN_USERNAME=
ADMIN_PASSWORD=
APP_SECRET=
ENCRYPTION_KEY=

# Local IP geolocation database (MaxMind GeoLite2). Enables fast, unlimited,
# offline city/ASN lookups so scanning thousands of rotating upstreams no longer
# hits the free online geo APIs' rate limits. Optional: if no database file is
# present the scanner automatically falls back to the online providers.
#   1) Get a FREE license key: https://www.maxmind.com/en/geolite2/signup
#   2) Download/refresh the databases:
#        MAXMIND_LICENSE_KEY=your_key node scripts/update-geoip.mjs
#   3) Schedule that command (e.g. weekly cron) to keep the data fresh.
MAXMIND_LICENSE_KEY=
# Directory holding GeoLite2-City.mmdb / GeoLite2-ASN.mmdb (default: data/geoip).
GEOIP_DB_DIR=
# Override database file names if needed (defaults shown).
GEOIP_CITY_DB=GeoLite2-City.mmdb
GEOIP_ASN_DB=GeoLite2-ASN.mmdb
# Set to "false" to force-disable local geo and always use the online providers.
GEOIP_ENABLED=
